---
---

<div
  class="fixed inset-0 z-9999 flex flex-col items-center justify-center bg-primary pointer-events-none"
  id="wiper-overlay"
  transition:persist
  aria-hidden="true"
>
  <span
    class="text-bgColor text-sm md:text-base uppercase tracking-[0.4em] font-medium opacity-60"
    id="wiper-label"
  >
  </span>
</div>

<style>
  #wiper-overlay {
    transform: translateY(100%);
  }
</style>

<script>
  import { animate } from "motion";

  let wipeIn: ReturnType<typeof animate> | null = null;

  function getPageName(path: string): string {
    const segment = path.split("/")[1];
    if (!segment) return "Home";
    return segment.charAt(0).toUpperCase() + segment.slice(1);
  }

  document.addEventListener("astro:before-preparation", (event) => {
    const e = event as any;
    const to: URL = e.to ?? new URL("/", window.location.origin);
    const label = document.querySelector("#wiper-label");

    if (label) {
      label.textContent = `Going to ${getPageName(to.pathname)}`;
    }

    wipeIn = (animate as any)(
      "#wiper-overlay",
      { transform: ["translateY(100%)", "translateY(0%)"] },
      { duration: 0.25, easing: [0.76, 0, 0.24, 1] }
    );

    if (label) {
      (animate as any)(
        "#wiper-label",
        { opacity: [0, 0.6], y: [20, 0] },
        { duration: 0.15, delay: 0.1, easing: "ease-out" }
      );
    }
  });

  document.addEventListener("astro:before-swap", (event) => {
    const e = event as any;
    const originalSwap: (() => void) | undefined = e.swap;

    if (originalSwap) {
      e.swap = async () => {
        if (wipeIn) {
          await wipeIn.finished;
        }
        originalSwap();
      };
    }
  });

  document.addEventListener("astro:after-swap", () => {
    const label = document.querySelector("#wiper-label");

    if (label) {
      (animate as any)(
        "#wiper-label",
        { opacity: [0.6, 0], y: [0, -20] },
        { duration: 0.15, easing: "ease-in" }
      );
    }

    (animate as any)(
      "#wiper-overlay",
      { transform: ["translateY(0%)", "translateY(-100%)"] },
      { duration: 0.25, delay: 0.05, easing: [0.76, 0, 0.24, 1] }
    );
  });
</script>
