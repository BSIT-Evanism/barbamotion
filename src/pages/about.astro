---
import Layout from "../layouts/Layout.astro";
import BentoBox from "../components/BentoBox.astro";
import SkillsSection from "../components/SkillsSection.astro";
import { PositionButton } from "../components/Position-Button";
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../keystatic.config";

const reader = createReader(process.cwd(), keystaticConfig);

const profile = await reader.singletons.profile.read();
const experience = await reader.singletons.experience.read();
const education = await reader.singletons.education.read();
const languages = await reader.singletons.languages.read();
---

<Layout title="About">
  <main class="bg-bgColor min-h-screen">
    <!-- Hero / Contact Header -->
    <section class="px-4 md:px-8 pt-12 md:pt-20 pb-8 md:pb-16">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
          <div class="md:col-span-1">
            <img
              src={profile?.photo ?? "/portrait-1.jpeg"}
              alt={profile?.name ?? "Profile"}
              class="w-full aspect-square object-cover rounded-2xl shadow-lg"
            />
          </div>
          <div class="md:col-span-2">
            <h1 class="text-5xl md:text-7xl font-bold text-primary mb-2">
              {profile?.name ?? "Evan Solanoy"}
            </h1>
            <p class="text-2xl md:text-3xl text-secondary font-medium mb-6">
              {profile?.title}
            </p>
            <p class="text-lg text-secondary leading-relaxed mb-6">
              {profile?.summary}
            </p>
            <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-secondary">
              {profile?.location && (
                <span class="flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
                  {profile.location}
                </span>
              )}
              {profile?.email && (
                <a href={`mailto:${profile.email}`} class="flex items-center gap-2 hover:text-primary transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                  {profile.email}
                </a>
              )}
              {profile?.phone && (
                <span class="flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  {profile.phone}
                </span>
              )}
              {profile?.website && (
                <a href={profile.website} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 hover:text-primary transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                  {profile.website.replace(/^https?:\/\//, '')}
                </a>
              )}
            </div>
            <div class="flex gap-4 mt-6">
              {profile?.linkedin && (
                <a href={profile.linkedin} target="_blank" rel="noopener noreferrer" class="text-secondary hover:text-primary transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
                </a>
              )}
              {profile?.github && (
                <a href={profile.github} target="_blank" rel="noopener noreferrer" class="text-secondary hover:text-primary transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Work Experience Timeline -->
    {
      experience && (
        <section class="px-4 md:px-8 py-12 md:py-16">
          <div class="max-w-5xl mx-auto">
            <h2 class="text-3xl md:text-5xl font-bold text-primary mb-8 md:mb-12">
              Experience
            </h2>
            <div class="space-y-6">
              {experience.jobs.map((job, i) => (
                <BentoBox class="overflow-hidden">
                  <div class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-0">
                    <div class={`p-6 ${i === 0 ? "bg-primary text-bgColor" : "bg-secondary text-bgColor"}`}>
                      <p class="text-sm font-semibold uppercase tracking-wider opacity-80">
                        {job.startDate} — {job.endDate}
                      </p>
                      {job.current && (
                        <span class="inline-block mt-2 text-xs bg-bgColor/20 px-2 py-0.5 rounded-full">
                          Current
                        </span>
                      )}
                      {job.location && (
                        <p class="text-sm mt-3 opacity-60">{job.location}</p>
                      )}
                    </div>
                    <div class="p-6">
                      <h3 class="text-xl md:text-2xl font-bold text-platinum mb-1">
                        {job.role}
                      </h3>
                      <p class="text-bgColor text-lg font-medium opacity-80 mb-4">
                        {job.company}
                      </p>
                      <ul class="space-y-2">
                        {job.highlights.map((highlight) => (
                          <li class="flex items-start gap-2 text-sm text-bgColor opacity-70 leading-relaxed">
                            <span class="text-primary mt-1 flex-shrink-0">▸</span>
                            <span>{highlight}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>
                </BentoBox>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <!-- Education & Languages -->
    <section class="px-4 md:px-8 py-12 md:py-16">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="md:col-span-2">
            <h2 class="text-3xl md:text-5xl font-bold text-primary mb-8">
              Education
            </h2>
            {
              education && education.schools.map((school) => (
                <BentoBox class="mb-4">
                  <div class="p-6">
                    <h3 class="text-xl md:text-2xl font-bold text-platinum mb-1">
                      {school.degree}
                    </h3>
                    <p class="text-bgColor text-lg opacity-80 mb-2">
                      {school.institution}
                    </p>
                    <div class="flex items-center gap-4 text-sm text-bgColor opacity-60">
                      {school.location && <span>{school.location}</span>}
                      <span>·</span>
                      <span>Class of {school.year}</span>
                    </div>
                  </div>
                </BentoBox>
              ))
            }
          </div>
          <div>
            <h2 class="text-3xl md:text-5xl font-bold text-primary mb-8">
              Languages
            </h2>
            {
              languages && (
                <BentoBox>
                  <div class="p-6 space-y-4">
                    {languages.items.map((lang) => (
                      <div>
                        <div class="flex items-center justify-between mb-1">
                          <span class="text-platinum font-medium">{lang.name}</span>
                          <span class="text-bgColor text-xs uppercase tracking-wider opacity-60">
                            {lang.level}
                          </span>
                        </div>
                        <div class="h-1 bg-bgColor/20 rounded-full overflow-hidden">
                          <div
                            class="h-full rounded-full bg-primary"
                            style={`width: ${lang.level === 'native' ? '100%' : lang.level === 'fluent' ? '85%' : lang.level === 'conversational' ? '65%' : '40%'};`}
                          />
                        </div>
                      </div>
                    ))}
                  </div>
                </BentoBox>
              )
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Skills -->
    <section class="bg-secondary py-12 md:py-20">
      <SkillsSection />
    </section>

    <!-- CTA -->
    <section class="px-4 md:px-8 py-12 md:py-20">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-5xl font-bold text-primary mb-4">
          Want to know more?
        </h2>
        <p class="text-lg text-secondary mb-8">
          Check out my projects or get in touch — I'm always open to a conversation.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <PositionButton client:only="react" text="View Projects" link="/projects" />
          <PositionButton client:only="react" text="Contact Me" link="/contact" />
        </div>
      </div>
    </section>
  </main>
</Layout>
