---
import Layout from "../layouts/Layout.astro";
import { PositionButton } from "../components/Position-Button";
import { getCollection } from "astro:content";

const posts = await getCollection("posts");

const sortedPosts = posts.sort((a, b) => {
  const dateA = new Date(a.data.publishDate).getTime();
  const dateB = new Date(b.data.publishDate).getTime();
  return dateB - dateA;
});

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const tagColors: Record<string, string> = {
  Astro: "bg-purple-500/20 text-purple-300",
  Animation: "bg-blue-500/20 text-blue-300",
  Design: "bg-pink-500/20 text-pink-300",
  Hospitality: "bg-emerald-500/20 text-emerald-300",
  Leadership: "bg-amber-500/20 text-amber-300",
};

function getTagColor(tag: string): string {
  return tagColors[tag] ?? "bg-white/10 text-white";
}
---

<Layout title="Blog">
  <main class="bg-bgColor min-h-screen">
    <section class="px-4 md:px-8 pt-12 md:pt-20 pb-8">
      <div class="max-w-6xl mx-auto">
        <h1 class="text-5xl md:text-8xl font-bold text-primary mb-4">
          Blog
        </h1>
        <p class="text-lg md:text-xl text-secondary max-w-2xl leading-relaxed">
          Thoughts on web development, hospitality tech, design, and the
          creative process of building digital experiences.
        </p>
      </div>
    </section>

    <!-- Latest Post (featured) -->
    {
      sortedPosts.length > 0 && (
        <section class="px-4 md:px-8 py-6 md:py-8">
          <div class="max-w-6xl mx-auto">
            <h2 class="text-sm uppercase tracking-[0.3em] text-secondary font-semibold mb-6">
              Latest
            </h2>
            <a href={`/blog/${sortedPosts[0].id}`} class="group block">
              <div class="bg-secondary rounded-2xl overflow-hidden border border-white/5 hover:border-white/15 transition-all duration-300">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
                  <div class="relative overflow-hidden h-56 md:h-80">
                    {sortedPosts[0].data.coverImage ? (
                      <img
                        src={sortedPosts[0].data.coverImage}
                        alt={sortedPosts[0].data.title}
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                      />
                    ) : (
                      <div class="w-full h-full bg-primary flex items-center justify-center">
                        <span class="text-bgColor text-6xl font-bold opacity-20">
                          {sortedPosts[0].data.title.charAt(0)}
                        </span>
                      </div>
                    )}
                  </div>
                  <div class="p-8 md:p-10 flex flex-col justify-center">
                    <div class="flex items-center gap-2 mb-4 flex-wrap">
                      {sortedPosts[0].data.tags.map((tag) => (
                        <span class={`text-xs px-3 py-1 rounded-full uppercase tracking-wider ${getTagColor(tag)}`}>
                          {tag}
                        </span>
                      ))}
                    </div>
                    <h3 class="text-2xl md:text-4xl font-bold text-platinum mb-3 group-hover:text-bgColor transition-colors">
                      {sortedPosts[0].data.title}
                    </h3>
                    <p class="text-bgColor text-base md:text-lg leading-relaxed opacity-70 mb-4">
                      {sortedPosts[0].data.excerpt}
                    </p>
                    <div class="flex items-center gap-3 text-bgColor text-sm opacity-50">
                      <span>{formatDate(sortedPosts[0].data.publishDate)}</span>
                    </div>
                    <div class="mt-4 flex items-center gap-2 text-bgColor text-sm font-medium opacity-50 group-hover:opacity-100 transition-opacity">
                      <span>Read More</span>
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
                    </div>
                  </div>
                </div>
              </div>
            </a>
          </div>
        </section>
      )
    }

    <!-- Rest of the posts -->
    {
      sortedPosts.length > 1 && (
        <section class="px-4 md:px-8 py-6 md:py-12">
          <div class="max-w-6xl mx-auto">
            <h2 class="text-sm uppercase tracking-[0.3em] text-secondary font-semibold mb-6">
              All Posts
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              {sortedPosts.slice(1).map((post) => (
                <a href={`/blog/${post.id}`} class="group block bg-secondary rounded-xl overflow-hidden border border-white/5 hover:border-white/15 transition-all duration-300 hover:scale-[1.02]">
                  <div class="relative overflow-hidden h-40">
                    {post.data.coverImage ? (
                      <img
                        src={post.data.coverImage}
                        alt={post.data.title}
                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      />
                    ) : (
                      <div class="w-full h-full bg-primary flex items-center justify-center">
                        <span class="text-bgColor text-4xl font-bold opacity-20">
                          {post.data.title.charAt(0)}
                        </span>
                      </div>
                    )}
                  </div>
                  <div class="p-5">
                    <div class="flex items-center gap-2 mb-3 flex-wrap">
                      {post.data.tags.slice(0, 2).map((tag) => (
                        <span class={`text-xs px-2 py-0.5 rounded-full ${getTagColor(tag)}`}>
                          {tag}
                        </span>
                      ))}
                    </div>
                    <h3 class="text-lg font-bold text-platinum mb-2 group-hover:text-bgColor transition-colors">
                      {post.data.title}
                    </h3>
                    <p class="text-bgColor text-sm leading-relaxed opacity-60 mb-3 line-clamp-3">
                      {post.data.excerpt}
                    </p>
                    <div class="text-bgColor text-xs opacity-40">
                      {formatDate(post.data.publishDate)}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <!-- CTA -->
    <section class="px-4 md:px-8 py-12 md:py-20">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-5xl font-bold text-primary mb-4">
          Want to collaborate?
        </h2>
        <PositionButton client:only="react" text="Get in Touch" link="/contact" />
      </div>
    </section>
  </main>
</Layout>
